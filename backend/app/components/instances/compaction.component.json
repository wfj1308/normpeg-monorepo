  "path": {
    "steps": [
      {
        "step_id": "determine_zone",
        "action": "lookup",
        "lookup_ref": "zone_by_layer_depth",
        "input_fields": [
          "layer_depth"
        ],
        "output_field": "zone_type"
      },
      {
        "step_id": "determine_standard",
        "action": "lookup",
        "lookup_ref": "standard_by_zone",
        "input_fields": [
          "zone_type"
        ],
        "output_field": "standard_value"
      },
      {
        "step_id": "lookup_tolerance",
        "action": "lookup",
        "lookup_ref": "tolerance_by_zone",
        "input_fields": [
          "zone_type"
        ],
        "output_field": "tolerance"
      },
      {
        "step_id": "calc_lower_bound",
        "action": "formula",
        "formula_ref": "lower_bound_formula",
        "output_field": "lower_bound"
      },
      {
        "step_id": "calc_wet_density",
        "action": "formula",
        "formula_ref": "wet_density_formula",
        "output_field": "wet_density",
        "when": "exists(raw_data)"
      },
      {
        "step_id": "calc_dry_density",
        "action": "formula",
        "formula_ref": "dry_density_formula",
        "output_field": "dry_density",
        "when": "exists(raw_data)"
      },
      {
        "step_id": "calc_compaction",
        "action": "formula",
        "formula_ref": "compaction_from_raw_formula",
        "output_field": "compaction_degree_from_raw",
        "when": "exists(raw_data)"
      },
      {
        "step_id": "resolve_compaction_degree",
        "action": "formula",
        "formula_ref": "resolve_compaction_formula",
        "output_field": "compaction_degree_resolved"
      },
      {
        "step_id": "calc_representative_from_paragraph",
        "action": "aggregate",
        "method": "t_distribution_95",
        "input_field": "paragraph_values",
        "output_field": "paragraph_representative",
        "when": "exists(paragraph_values)"
      },
      {
        "step_id": "resolve_representative_value",
        "action": "formula",
        "formula_ref": "resolve_representative_formula",
        "output_field": "representative_value_resolved"
      }
    ],
    "formulas": {
      "lower_bound_formula": "standard_value - tolerance",
      "wet_density_formula": "(raw_data.mass_hole_sand / raw_data.sand_density) / raw_data.volume_ring",
      "dry_density_formula": "wet_density / (1 + raw_data.moisture_content / 100)",
      "compaction_from_raw_formula": "dry_density / raw_data.max_dry_density * 100",
      "resolve_compaction_formula": "if(exists(compaction_degree_from_raw), compaction_degree_from_raw, compaction_degree)",
      "resolve_representative_formula": "if(exists(paragraph_representative), paragraph_representative, if(exists(representative_value), representative_value, compaction_degree_resolved))"
    },
    "lookup_tables": {
      "zone_by_layer_depth": {
        "0-0.8m": "Z96",
        "0.8-1.5m": "Z96",
        ">1.5m": "Z94"
      },
      "standard_by_zone": {
        "Z96": 95.0,
        "Z94": 94.0,
        "Z92": 92.0
      },
      "tolerance_by_zone": {
        "Z96": 2.0,
        "Z94": 2.0,
        "Z92": 2.0
      }
    },
    "derived_fields": [
      "zone_type",
      "standard_value",
      "tolerance",
      "lower_bound",
      "wet_density",
      "dry_density",
      "compaction_degree_resolved",
      "representative_value_resolved"
    ]
  },
  "gate": {
    "rules": [
      {
        "rule_id": "single_point_rule",
        "condition": {
          "operator": "tolerance",
          "mode": "lower_bound",
          "actual": "compaction_degree_resolved",
          "expected": "standard_value",
          "tolerance": "tolerance"
        },
        "severity": "blocking",
        "on_fail": "block",
        "clause_refs": [
          "JTG_F80_1_2017.4.2.1.single_point"
        ]
      },
      {
        "rule_id": "representative_value_rule",
        "condition": "representative_value_resolved >= standard_value",
        "severity": "critical",
        "on_fail": "critical",
        "clause_refs": [
          "JTG_F80_1_2017.4.2.1.representative"
        ]
      },
      {
        "rule_id": "extreme_value_rule",
        "condition": "compaction_degree_resolved >= lower_bound - 1",
        "severity": "warning",
        "on_fail": "warn",
        "clause_refs": [
          "JTG_F80_1_2017.4.2.1.extreme"
        ]
      },
      {
        "rule_id": "override_evidence_rule",
        "condition": "override_requested == False or exists(override_evidence)",
        "severity": "blocking",
        "on_fail": "manual_override",
        "clause_refs": [
          "JTG_F80_1_2017.override"
        ]
      }
    ],
    "references": [
      "JTG_F80_1_2017.4.2.1",
      "JTG_3450_2019.T0921"
    ],
    "clause_refs": [
      "JTG_F80_1_2017.4.2.1",
      "JTG_3450_2019.T0921"
    ]
  },
