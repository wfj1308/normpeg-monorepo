{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://layerpeg.local/schemas/patch.schema.json",
  "title": "Patch Schema",
  "description": "Standard patch payload for component DSL updates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "patch_id",
    "component_id",
    "target",
    "operation",
    "old_value",
    "new_value",
    "effective_date",
    "reason",
    "author"
  ],
  "properties": {
    "patch_id": {
      "type": "string",
      "minLength": 1
    },
    "component_id": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "type": "string",
      "enum": [
        "replace",
        "add",
        "remove"
      ]
    },
    "old_value": {
      "oneOf": [
        { "type": "number" },
        { "type": "string" },
        { "type": "boolean" },
        { "type": "object" },
        { "type": "array" },
        { "type": "null" }
      ]
    },
    "new_value": {
      "oneOf": [
        { "type": "number" },
        { "type": "string" },
        { "type": "boolean" },
        { "type": "object" },
        { "type": "array" },
        { "type": "null" }
      ]
    },
    "effective_date": {
      "type": "string",
      "format": "date"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
