{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://layerpeg.local/schemas/execution-result.schema.json",
  "title": "Execution Result Schema",
  "description": "Canonical execution output format produced by Layer2 and consumed by Layer3 packaging.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "execution_id",
    "component_id",
    "version",
    "project_id",
    "branch_id",
    "effective_overrides",
    "resolved_context",
    "v_address",
    "source",
    "spec_id",
    "spec_version",
    "spec_file",
    "compile_hash",
    "input",
    "normalized_input",
    "path_outputs",
    "path_trace",
    "merkle_root",
    "proof_path",
    "gate",
    "gate_trace",
    "state_trace",
    "proof",
    "final_status",
    "lifecycle_status",
    "clause_refs",
    "explanation_seed"
  ],
  "properties": {
    "execution_id": {
      "type": "string",
      "minLength": 1
    },
    "component_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "branch_id": {
      "type": "string",
      "minLength": 1
    },
    "effective_overrides": {
      "type": "object",
      "additionalProperties": true
    },
    "resolved_context": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "project_id",
        "branch_id",
        "component_id",
        "merge_order",
        "applied_items",
        "effective_overrides",
        "path",
        "gate"
      ],
      "properties": {
        "project_id": {
          "type": "string"
        },
        "branch_id": {
          "type": "string"
        },
        "component_id": {
          "type": "string"
        },
        "component_version": {
          "type": "string"
        },
        "merge_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "applied_items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "effective_overrides": {
          "type": "object",
          "additionalProperties": true
        },
        "path": {
          "type": "object",
          "additionalProperties": true
        },
        "gate": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "v_address": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": [
        "builtin",
        "specir"
      ]
    },
    "spec_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "spec_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "spec_file": {
      "type": [
        "string",
        "null"
      ]
    },
    "compile_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "spec_anchor": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "spec_id",
        "hash",
        "version"
      ],
      "properties": {
        "spec_id": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "minLength": 16
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "test_method": {
      "type": [
        "string",
        "null"
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    },
    "normalized_input": {
      "type": "object",
      "additionalProperties": true
    },
    "path_outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "path_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "merkle_root": {
      "type": "string"
    },
    "proof_path": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sibling_hash",
          "direction"
        ],
        "properties": {
          "sibling_hash": {
            "type": "string"
          },
          "direction": {
            "type": "string",
            "enum": [
              "left",
              "right"
            ]
          }
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_results",
        "summary_status"
      ],
      "properties": {
        "rule_results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/rule_result"
          }
        },
        "summary_status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "BLOCKED",
            "CRITICAL",
            "OVERRIDDEN",
            "WARNING"
          ]
        },
        "failed_rule_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "gate_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "state_trace": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/state_trace_item"
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_hash",
        "hash_method",
        "canonical_payload"
      ],
      "properties": {
        "proof_hash": {
          "type": "string",
          "minLength": 16
        },
        "hash_method": {
          "type": "string",
          "enum": [
            "sha256",
            "sha3_256",
            "blake3"
          ]
        },
        "canonical_payload": {
          "type": "object",
          "additionalProperties": true
        },
        "proof_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "signature": {
          "type": [
            "string",
            "null"
          ]
        },
        "signature_algorithm": {
          "type": [
            "string",
            "null"
          ]
        },
        "spec_anchor": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "spec_id",
            "hash",
            "version"
          ],
          "properties": {
            "spec_id": {
              "type": "string",
              "minLength": 1
            },
            "hash": {
              "type": "string",
              "minLength": 16
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "v_address": {
          "type": "string",
          "minLength": 1
        },
        "proof_id": {
          "type": "string",
          "minLength": 1
        },
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "enum": [
            "EXECUTE",
            "MERGE",
            "ABANDON"
          ]
        },
        "component_id": {
          "type": "string"
        },
        "execution_id": {
          "type": "string"
        },
        "ledger_index": {
          "type": "integer",
          "minimum": 1
        },
        "previous_chain_hash": {
          "type": "string"
        },
        "chain_hash": {
          "type": "string"
        },
        "main_chain_hash": {
          "type": "string"
        },
        "fork_chain_hash": {
          "type": "string"
        },
        "branch_id": {
          "type": "string",
          "minLength": 1
        },
        "parent_branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "fork_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "fork_point": {
          "type": [
            "string",
            "null"
          ]
        },
        "merge_decision": {
          "type": [
            "string",
            "null"
          ]
        },
        "merged_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "merged_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "proof_schema_version": {
          "type": "string"
        },
        "branch_history": {
          "type": "object",
          "additionalProperties": true
        },
        "workflow_history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "execution_context_hash": {
          "type": "string",
          "minLength": 16
        },
        "merkle_root": {
          "type": "string"
        },
        "chain_merkle_root": {
          "type": "string"
        },
        "proof_path": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "sibling_hash",
              "direction"
            ],
            "properties": {
              "sibling_hash": {
                "type": "string"
              },
              "direction": {
                "type": "string",
                "enum": [
                  "left",
                  "right"
                ]
              }
            }
          }
        },
        "chain_proof_path": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "sibling_hash",
              "direction"
            ],
            "properties": {
              "sibling_hash": {
                "type": "string"
              },
              "direction": {
                "type": "string",
                "enum": [
                  "left",
                  "right"
                ]
              }
            }
          }
        },
        "merkle_leaf_index": {
          "type": "integer",
          "minimum": 0
        },
        "merkle_tree_size": {
          "type": "integer",
          "minimum": 0
        },
        "signatures": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "did",
              "role",
              "signature"
            ],
            "properties": {
              "did": {
                "type": "string"
              },
              "role": {
                "type": "string"
              },
              "signature": {
                "type": "string"
              }
            }
          }
        },
        "timestamp": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "final_status": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL",
        "BLOCKED",
        "CRITICAL",
        "OVERRIDDEN",
        "WARNING"
      ]
    },
    "lifecycle_status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "COMPUTED",
        "VALIDATED",
        "QUALIFIED",
        "REJECTED",
        "OVERRIDDEN",
        "ARCHIVED"
      ]
    },
    "clause_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "explanation_seed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_key",
        "facts"
      ],
      "properties": {
        "template_key": {
          "type": "string"
        },
        "locale": {
          "type": "string"
        },
        "facts": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  },
  "$defs": {
    "rule_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "condition",
        "severity",
        "passed",
        "actual_value",
        "expected_value"
      ],
      "properties": {
        "rule_id": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "blocking",
            "critical"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "actual_value": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        },
        "expected_value": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        },
        "message": {
          "type": "string"
        }
      }
    },
    "state_trace_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "entered_at"
      ],
      "properties": {
        "state": {
          "type": "string"
        },
        "entered_at": {
          "type": "string",
          "format": "date-time"
        },
        "trigger": {
          "type": "string"
        },
        "meta": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
