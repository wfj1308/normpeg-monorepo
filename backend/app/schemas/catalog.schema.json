{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://layerpeg.local/schemas/catalog.schema.json",
  "title": "Catalog Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "catalog_id",
    "catalog_name",
    "standard_id",
    "standard_version",
    "version",
    "status",
    "components",
    "dependencies",
    "metadata"
  ],
  "properties": {
    "catalog_id": {
      "type": "string",
      "minLength": 1
    },
    "catalog_name": {
      "type": "string",
      "minLength": 1
    },
    "standard_id": {
      "type": "string",
      "minLength": 1
    },
    "standard_version": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "component_id"
        ],
        "properties": {
          "component_id": {
            "type": "string",
            "minLength": 1
          },
          "component_name": {
            "type": "string"
          },
          "component_version": {
            "type": "string"
          },
          "component_status": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "from_component_id",
          "to_component_id",
          "dependency_type"
        ],
        "properties": {
          "from_component_id": {
            "type": "string",
            "minLength": 1
          },
          "to_component_id": {
            "type": "string",
            "minLength": 1
          },
          "dependency_type": {
            "type": "string",
            "enum": [
              "required",
              "optional",
              "reference"
            ]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "patches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/patch_item"
      }
    },
    "overrides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/override_item"
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "category_id",
          "name",
          "work_items"
        ],
        "properties": {
          "category_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "work_items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "work_item_id",
                "name",
                "component_ids"
              ],
              "properties": {
                "work_item_id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "component_ids": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "references": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "gate": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "rules"
                  ],
                  "properties": {
                    "rules": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                          "rule_id",
                          "operator",
                          "severity"
                        ],
                        "properties": {
                          "rule_id": {
                            "type": "string"
                          },
                          "operator": {
                            "type": "string",
                            "enum": [
                              "all_components_in_status",
                              "pass_rate_gte"
                            ]
                          },
                          "component_ids": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "allowed_statuses": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "pass_statuses": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "min_rate": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          },
                          "severity": {
                            "type": "string",
                            "enum": [
                              "info",
                              "warning",
                              "blocking",
                              "critical"
                            ]
                          },
                          "on_fail": {
                            "type": "string",
                            "enum": [
                              "warn",
                              "block",
                              "critical"
                            ]
                          },
                          "clause_refs": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "patch_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "patch_id",
        "component_id",
        "target",
        "operation",
        "old_value",
        "new_value",
        "effective_date",
        "reason",
        "author"
      ],
      "properties": {
        "patch_id": {
          "type": "string",
          "minLength": 1
        },
        "component_id": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "type": "string",
          "enum": [
            "replace",
            "add",
            "remove"
          ]
        },
        "old_value": {
          "oneOf": [
            { "type": "number" },
            { "type": "string" },
            { "type": "boolean" },
            { "type": "object" },
            { "type": "array" },
            { "type": "null" }
          ]
        },
        "new_value": {
          "oneOf": [
            { "type": "number" },
            { "type": "string" },
            { "type": "boolean" },
            { "type": "object" },
            { "type": "array" },
            { "type": "null" }
          ]
        },
        "effective_date": {
          "type": "string",
          "format": "date"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "project_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "override_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "override_id",
        "component_id",
        "project_id",
        "target",
        "value",
        "approved_by",
        "evidence",
        "effective_date"
      ],
      "properties": {
        "override_id": {
          "type": "string",
          "minLength": 1
        },
        "component_id": {
          "type": "string",
          "minLength": 1
        },
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "oneOf": [
            { "type": "number" },
            { "type": "string" },
            { "type": "boolean" },
            { "type": "object" },
            { "type": "array" },
            { "type": "null" }
          ]
        },
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "oneOf": [
            { "type": "string" },
            { "type": "object" }
          ]
        },
        "effective_date": {
          "type": "string",
          "format": "date"
        }
      }
    }
  }
}
