# Copy this file to .env in the same directory.
# PowerShell:
#   Copy-Item .env.example .env

# Ollama (default local)
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
NORMPEG_AI_MODEL=deepseek-chat

# Optional: only needed for cloud OpenAI-compatible providers
OPENAI_API_KEY=

# Optional:
# GATE_URL=http://host.docker.internal:8080/v1/gate/validate
