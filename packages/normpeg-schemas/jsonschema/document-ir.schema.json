{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normpeg.local/schemas/document-ir.schema.json",
  "title": "Document IR Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "pages"
  ],
  "properties": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doc_id",
        "norm_id",
        "norm_name",
        "version",
        "source_file_hash",
        "page_count"
      ],
      "properties": {
        "doc_id": {
          "type": "string",
          "minLength": 1
        },
        "norm_id": {
          "type": "string",
          "minLength": 1
        },
        "norm_name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "source_file_hash": {
          "type": "string",
          "minLength": 1
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/page"
      }
    }
  },
  "$defs": {
    "bbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x0",
        "y0",
        "x1",
        "y1"
      ],
      "properties": {
        "x0": { "type": "number" },
        "y0": { "type": "number" },
        "x1": { "type": "number" },
        "y1": { "type": "number" }
      }
    },
    "text_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "block_id",
        "type",
        "text",
        "source_text",
        "page_no",
        "bbox",
        "confidence",
        "source_hash"
      ],
      "properties": {
        "block_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "heading",
            "chapter",
            "section",
            "clause",
            "paragraph",
            "table",
            "formula",
            "figure",
            "note"
          ]
        },
        "heading_level": {
          "type": "string",
          "enum": ["", "h1", "h2", "h3"]
        },
        "clause_id": {
          "type": "string"
        },
        "normRef": {
          "type": "string"
        },
        "unresolved_reason": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "source_text": {
          "type": "string"
        },
        "page_no": {
          "type": "integer",
          "minimum": 1
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_hash": {
          "type": "string",
          "minLength": 1
        },
        "table": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rows", "cols", "merged_cells"],
          "properties": {
            "rows": { "type": "integer", "minimum": 0 },
            "cols": { "type": "integer", "minimum": 0 },
            "merged_cells": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_no",
        "width",
        "height",
        "text_blocks"
      ],
      "properties": {
        "page_no": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "text_blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/text_block"
          }
        }
      }
    }
  },
  "$comment": "Global uniqueness of block_id across pages must be enforced by runtime validator."
}
