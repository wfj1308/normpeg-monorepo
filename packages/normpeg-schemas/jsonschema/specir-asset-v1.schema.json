{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normpeg.local/schemas/specir-asset-v1.schema.json",
  "title": "SpecIR Asset v1 Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specir_id",
    "normRef",
    "semantic_type",
    "subject",
    "condition",
    "slotKey",
    "constraint",
    "evidence",
    "confidence",
    "review_status",
    "execution_status"
  ],
  "properties": {
    "specir_id": {
      "type": "string",
      "minLength": 1
    },
    "normRef": {
      "type": "string",
      "minLength": 1
    },
    "semantic_type": {
      "type": "string",
      "enum": [
        "threshold_constraint",
        "range_constraint",
        "existence_requirement",
        "process_requirement",
        "material_requirement",
        "method_requirement",
        "reference_requirement",
        "non_executable_clause"
      ]
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "condition": {
      "type": "string"
    },
    "slotKey": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9_]*){3}$",
      "description": "domain.object.property.measure"
    },
    "constraint": {
      "$ref": "#/$defs/constraint"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "review_status": {
      "type": "string",
      "enum": [
        "pending_review",
        "approved",
        "rejected",
        "modified"
      ]
    },
    "execution_status": {
      "type": "string",
      "enum": [
        "executable",
        "partial_executable",
        "not_executable",
        "needs_slot",
        "needs_formula",
        "needs_runtime"
      ]
    },
    "runtime_requirements": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "manual_input",
          "sensor",
          "lab_test",
          "design_value",
          "measured_value",
          "bim_model",
          "formula_engine",
          "external_standard",
          "human_judgement"
        ]
      }
    },
    "runtime_mode": {
      "type": "string",
      "enum": [
        "automatic",
        "semi_automatic",
        "manual_confirmed",
        "non_executable"
      ]
    },
    "derivation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_derivable",
        "gate_derivable"
      ],
      "properties": {
        "rule_derivable": {
          "type": "boolean"
        },
        "gate_derivable": {
          "type": "boolean"
        },
        "rule_id": {
          "type": "string"
        },
        "gate_id": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "operator",
        "value",
        "min",
        "max",
        "unit",
        "formula"
      ],
      "properties": {
        "field": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "value": {
          "oneOf": [
            { "type": "number" },
            { "type": "string" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "min": {
          "oneOf": [
            { "type": "number" },
            { "type": "null" }
          ]
        },
        "max": {
          "oneOf": [
            { "type": "number" },
            { "type": "null" }
          ]
        },
        "unit": {
          "type": "string"
        },
        "formula": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standard_code",
        "version",
        "clause_no",
        "page",
        "source_text"
      ],
      "properties": {
        "standard_code": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "clause_no": {
          "type": "string",
          "minLength": 1
        },
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "source_text": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
  ,
  "allOf": [
    {
      "if": {
        "properties": {
          "execution_status": { "enum": ["executable", "partial_executable"] }
        }
      },
      "then": {
        "required": ["slotKey"]
      }
    },
    {
      "if": {
        "properties": {
          "execution_status": { "const": "needs_runtime" }
        }
      },
      "then": {
        "required": ["runtime_requirements"]
      }
    },
    {
      "if": {
        "properties": {
          "runtime_mode": { "const": "non_executable" }
        }
      },
      "then": {
        "properties": {
          "semantic_type": { "const": "non_executable_clause" },
          "execution_status": { "const": "not_executable" }
        }
      }
    }
  ]
}
