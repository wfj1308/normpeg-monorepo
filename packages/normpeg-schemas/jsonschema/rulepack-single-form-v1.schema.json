{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normpeg.local/schemas/rulepack-single-form-v1.schema.json",
  "title": "Single Form Rulepack v1 Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "components",
    "rules",
    "gates",
    "traceability"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "form_code",
        "norm_id",
        "norm_version",
        "rulepack_version",
        "generated_at",
        "selection_mode",
        "counts"
      ],
      "properties": {
        "form_code": {
          "type": "string",
          "minLength": 1
        },
        "norm_id": {
          "type": "string",
          "minLength": 1
        },
        "norm_version": {
          "type": "string",
          "minLength": 1
        },
        "rulepack_version": {
          "type": "string",
          "const": "v1"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "selection_mode": {
          "type": "string",
          "enum": [
            "single_form"
          ]
        },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "components",
            "rules",
            "gates",
            "traceability"
          ],
          "properties": {
            "components": { "type": "integer", "minimum": 0 },
            "rules": { "type": "integer", "minimum": 0 },
            "gates": { "type": "integer", "minimum": 0 },
            "traceability": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "traceability": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/traceability"
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_id",
        "specir_id",
        "title",
        "normRef",
        "source_clause"
      ],
      "properties": {
        "component_id": { "type": "string", "minLength": 1 },
        "specir_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "normRef": { "type": "string", "minLength": 1 },
        "source_clause": { "type": "string", "minLength": 1 }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "specir_id",
        "field",
        "operator",
        "threshold",
        "unit",
        "condition",
        "source_specir_id",
        "normRef"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "specir_id": { "type": "string", "minLength": 1 },
        "field": { "type": "string", "minLength": 1 },
        "operator": { "type": "string", "minLength": 1 },
        "threshold": {
          "oneOf": [
            { "type": "number" },
            { "type": "string", "minLength": 1 },
            {
              "type": "array",
              "minItems": 1,
              "items": { "type": ["number", "string"] }
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "unit": { "type": "string" },
        "condition": { "type": "string" },
        "source_specir_id": { "type": "string", "minLength": 1 },
        "normRef": { "type": "string", "minLength": 1 }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "rule_id",
        "decision_logic",
        "on_pass",
        "on_fail"
      ],
      "properties": {
        "gate_id": { "type": "string", "minLength": 1 },
        "rule_id": { "type": "string", "minLength": 1 },
        "decision_logic": { "type": "string", "minLength": 1 },
        "on_pass": { "type": "string", "minLength": 1 },
        "on_fail": { "type": "string", "minLength": 1 }
      }
    },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "gate_id",
        "specir_id",
        "normRef",
        "source_text",
        "page_no"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "gate_id": { "type": "string", "minLength": 1 },
        "specir_id": { "type": "string", "minLength": 1 },
        "normRef": { "type": "string", "minLength": 1 },
        "source_text": { "type": "string", "minLength": 1 },
        "page_no": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$comment": "This schema enforces structure. Form-code ownership (no cross-form specir/rule/gate) requires runtime semantic validation across IDs and lineage."
}
