{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normpeg.local/schemas/slot-system-v1.schema.json",
  "title": "NormRef Global Slot System v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slotKey",
    "domain",
    "object",
    "property",
    "measure",
    "status"
  ],
  "properties": {
    "slotKey": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9_]*){3}$",
      "description": "domain.object.property.measure"
    },
    "domain": { "type": "string", "minLength": 1 },
    "object": { "type": "string", "minLength": 1 },
    "property": { "type": "string", "minLength": 1 },
    "measure": { "type": "string", "minLength": 1 },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "unit": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "experimental"]
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_from", "updated_at"],
      "properties": {
        "created_from": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    }
  }
}
