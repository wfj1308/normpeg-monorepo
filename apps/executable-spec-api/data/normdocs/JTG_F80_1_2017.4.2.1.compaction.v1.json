    "path": {
      "steps": [
        {
          "id": "calc_wet_density",
          "formula": "(mass_hole_sand / sand_density) / volume_ring",
          "output": "wet_density"
        },
        {
          "id": "calc_dry_density",
          "formula": "wet_density / (1 + moisture_content / 100)",
          "output": "dry_density"
        },
        {
          "id": "calc_compaction",
          "formula": "dry_density / max_dry_density * 100",
          "output": "compaction_degree"
        },
        {
          "id": "determine_zone",
          "lookup": {
            "table": "layer_depth_to_zone",
            "input": "layer_depth"
          },
          "output": "zone_type"
        },
        {
          "id": "determine_standard",
          "lookup": {
            "table": "standard_by_zone",
            "input": "zone_type"
          },
          "output": "standard_value"
        }
      ],
      "lookup_tables": {
        "layer_depth_to_zone": {
          "0-0.8m": "Z96",
