# -----------------------------
# NormPeg executable-spec-web
# Deployment environment config
# -----------------------------

# Environment profile: dev | staging | prod
NORMPEG_ENV=dev

# API binding
NORMPEG_HOST=0.0.0.0
PLATFORM_API_PORT=8790
QUALITY_API_PORT=8787
NORMPEG_PUBLIC_BASE_URL=http://localhost:8790
# Optional: external NL2Gate topic workbench entry (shown in UI "产品入口分层")
VITE_NL2GATE_WEB_URL=http://127.0.0.1:5173

# Tenant default (optional)
NORMPEG_DEFAULT_TENANT=default

# -----------------------------
# Database config
# -----------------------------
# Driver: memory | postgres | mysql | sqlite
NORMPEG_DB_DRIVER=memory
# Example: postgres://user:password@db-host:5432/normpeg
NORMPEG_DB_URL=
NORMPEG_DB_SCHEMA=public
NORMPEG_DB_SSL=false
NORMPEG_DB_POOL_MIN=1
NORMPEG_DB_POOL_MAX=10

# -----------------------------
# Storage config
# -----------------------------
# Driver: local | s3 | gcs | azureblob | minio
NORMPEG_STORAGE_DRIVER=local
NORMPEG_STORAGE_LOCAL_DIR=./.runtime-storage
NORMPEG_STORAGE_BUCKET=
NORMPEG_STORAGE_REGION=
NORMPEG_STORAGE_ENDPOINT=
NORMPEG_STORAGE_FORCE_PATH_STYLE=false

# -----------------------------
# Logging
# -----------------------------
# debug | info | warn | error
NORMPEG_LOG_LEVEL=debug
NORMPEG_LOG_JSON=false

# -----------------------------
# Anchor provider
# -----------------------------
# mock | ipfs_http
NORMPEG_ANCHOR_PROVIDER=mock
# Optional when using ipfs_http
NORMPEG_IPFS_ANCHOR_PROVIDER_NAME=ipfs_http_anchor_provider
NORMPEG_IPFS_API_BASE_URL=http://127.0.0.1:5001
NORMPEG_IPFS_AUTH_TOKEN=
NORMPEG_IPFS_PIN=true
