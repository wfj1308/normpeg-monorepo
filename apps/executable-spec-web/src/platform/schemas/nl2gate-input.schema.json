{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nl2gate-input.schema.json",
  "title": "Nl2GateInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["query"],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["preview", "evaluate"]
    },
    "conversationId": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
