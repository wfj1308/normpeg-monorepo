{
  "spuId": "highway.subgrade.compaction.4.2.1.soil@v1",
  "meta": {
    "name": "路基压实度（土质）",
    "norm": "JTG F80/1-2017",
    "clause": "4.2.1",
    "version": "v1",
    "category": "subgrade",
    "measuredItem": "compaction"
  },
  "data": {
    "inputs": [
      {
        "name": "massHoleSand",
        "type": "number",
        "unit": "g",
        "label": "灌入砂质量"
      },
      {
        "name": "volumeSand",
        "type": "number",
        "unit": "cm3",
        "label": "标定体积"
      },
      {
        "name": "moistureContent",
        "type": "number",
        "unit": "%",
        "label": "含水率"
      },
      {
        "name": "maxDryDensity",
        "type": "number",
        "unit": "g/cm3",
        "label": "最大干密度"
      }
    ],
    "outputs": [
      "wetDensity",
      "dryDensity",
      "compactionDegree"
    ]
  },
  "path": [
    {
      "step": "step_1",
      "formula": "wetDensity = massHoleSand / volumeSand"
    },
    {
      "step": "step_2",
      "formula": "dryDensity = wetDensity / (1 + moistureContent / 100)"
    },
    {
      "step": "step_3",
      "formula": "compactionDegree = (dryDensity / maxDryDensity) * 100"
    }
  ],
  "rules": [
    {
      "field": "compactionDegree",
      "operator": ">=",
      "value": 93,
      "message": "压实度必须 ≥ 93%"
    }
  ],
  "proof": {
    "resultField": "compactionDegree",
    "requiredSignatures": [
      "lab",
      "supervision"
    ]
  },
  "dependsOn": []
}
